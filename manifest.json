{
  "manifest_version": 3,
  "name": "Investown Partner Summary",
  "version": "1.0.0",
  "description": "Zobrazí celkovou investici u partnera na stránce projektu",
  "host_permissions": [
    "https://my.investown.cz/*",
    "https://api.investown.cz/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://my.investown.cz/*"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://my.investown.cz/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
